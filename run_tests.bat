@echo off
REM ===== COMPLETE TEST EXECUTION SCRIPT =====
REM Purpose: Build project and run all tests
REM

cd /d "%~dp0"

echo.
echo ??????????????????????????????????????????????????????????
echo ?       BULLET HOLE DETECTION SYSTEM - TEST SUITE        ?
echo ?              Building and Testing...                   ?
echo ??????????????????????????????????????????????????????????
echo.

REM Check if build directory exists
if not exist build (
    echo [INFO] Creating build directory...
    mkdir build
)

cd build

REM Step 1: CMake Configuration
echo [STEP 1] Configuring CMake...
cmake .. -G "Visual Studio 17 2022" -A x64 -DCMAKE_BUILD_TYPE=Release

if errorlevel 1 (
    echo [ERROR] CMake configuration failed!
    pause
    exit /b 1
)

echo [SUCCESS] CMake configuration complete
echo.

REM Step 2: Build all targets
echo [STEP 2] Building all targets...
cmake --build . --config Release --parallel 8

if errorlevel 1 (
    echo [ERROR] Build failed!
    pause
    exit /b 1
)

echo [SUCCESS] Build complete
echo.

REM Step 3: Run Unit Tests
echo [STEP 3] Running STEP 2 & 3 Unit Tests...
echo ????????????????????????????????????????????????????????

if exist ".\Release\test_step2_step3_unit.exe" (
    .\Release\test_step2_step3_unit.exe
    if errorlevel 1 (
        echo [WARNING] Unit test failed, but continuing...
    )
) else (
    echo [WARNING] Unit test executable not found
)

echo.

REM Step 4: Run Integration Tests
echo [STEP 4] Running Integration Tests...
echo ????????????????????????????????????????????????????????

if exist ".\Release\test_integration_real_image.exe" (
    .\Release\test_integration_real_image.exe
    if errorlevel 1 (
        echo [WARNING] Integration test failed, but continuing...
    )
) else (
    echo [WARNING] Integration test executable not found
)

echo.

REM Step 5: Run CTest
echo [STEP 5] Running CTest...
echo ????????????????????????????????????????????????????????
ctest --output-on-failure

echo.

echo ??????????????????????????????????????????????????????????
echo ?              TEST EXECUTION COMPLETE                   ?
echo ?                                                        ?
echo ? Next steps:                                            ?
echo ? 1. Review test outputs above                           ?
echo ? 2. Check for any errors or warnings                    ?
echo ? 3. Run VALIDATION_AND_METRICS_GUIDE.md if needed      ?
echo ? 4. Deploy to production when ready                     ?
echo ??????????????????????????????????????????????????????????
echo.

pause
